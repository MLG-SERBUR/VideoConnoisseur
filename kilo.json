# Application Configuration (kilo.json)
{
  "name": "video-processing-application",
  "version": "1.0.0",
  "description": "Advanced video processing and analysis application",
  "main": "app.py",
  "scripts": {
    "start": "python app.py",
    "dev": "FLASK_ENV=development python app.py",
    "test": "pytest tests/",
    "lint": "flake8",
    "format": "black"
  },
  "dependencies": {
    "flask": "^2.3.0",
    "flask-cors": "^4.0.0",
    "flask-sqlalchemy": "^3.1.0",
    "celery": "^5.3.0",
    "redis": "^4.6.0",
    "pillow": "^10.0.0",
    "numpy": "^1.24.0",
    "scikit-learn": "^1.3.0"
  },
  "devDependencies": {
    "pytest": "^7.4.0",
    "black": "^23.0.0"
  },
  "config": {
    "database": {
      "type": "postgresql",
      "host": "localhost",
      "port": 5432,
      "name": "video_processing_db"
    },
    "server": {
      "host": "0.0.0.0",
      "port": 5000
    },
    "processing": {
      "frameRate": 30,
      "targetSize": [224, 224],
      "maxFrames": 1000
    }
  }
}